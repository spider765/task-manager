<div class="content" id="content">

        <div class="dashboard">
          <h1>Welcome to Task Manager</h1>

  <div class="search">
    <input type="text" placeholder="Search tasks, projects, team...">

    <!-- Theme Toggle Slider -->
    <section class="dark-mode-toggle">
      <label class="switch">
        <input type="checkbox" id="themeToggle">
        <span class="slider round"></span>
      </label>
    </section>
  </div>




          <div class="info">
              <div class="card">
                  <h5>Total Tasks</h5>
                  <p id="totalTasks">0</p>
              </div>
              <div class="card">
                  <h5>Completed Tasks</h5>
                  <p id="completedTasks">0</p>
              </div>
              <div class="card">
                  <h5>Pending Tasks</h5>
                  <p id="pendingTasks">0</p>
              </div>
              <div class="member-list">
                  <h2>Team member List</h2>
                  <ul>
                      <li> 1 - <span>dan</span></li>
                      <li>2 - <span>dave</span></li>
                      <li> 3 - <span>emma</span></li>
                  </ul>
              </div>
          </div>

          <div class="management">

  <div class="task-list">
      <h2>Task List</h2>
      <ul>
          <li>Task 1 - <span>Due: 2025-03-10</span></li>
          <li>Task 2 - <span>Due: 2025-03-12</span></li>
          <li>Task 3 - <span>Due: 2025-03-15</span></li>
      </ul>
  </div>

    <!-- Task Filters -->
    <div class="task-filters">
        <select name="priority" id="filter-priority">
            <option value="">Priority</option>
            <option value="high">High</option>
            <option value="medium">Medium</option>
            <option value="low">Low</option>
        </select>

        <select name="assignee" id="filter-assignee">
            <option value="">Assignee</option>
            <option value="user1">John Doe</option>
            <option value="user2">Jane Smith</option>
            <option value="user3">Mike Johnson</option>
        </select>

        <input type="date" name="due-date" id="filter-due-date">
        <button id="apply-filters">Apply Filters</button>
    </div>

    <!-- Kanban Board -->
    <div class="kanban-board">

        <!-- To-Do Column -->
        <div class="kanban-column" id="todo">
            <h3>To-Do</h3>
            <div class="task-list1" id="todo-tasks">
                <div class="task-card" draggable="true">
                    <h4>Task Title 1</h4>
                    <p>Task Description</p>
                    <p><small>Due: 2025-03-20</small></p>
                </div>
                <div class="task-card" draggable="true">
                    <h4>Task Title 2</h4>
                    <p>Task Description</p>
                    <p><small>Due: 2025-03-22</small></p>
                </div>
            </div>
        </div>

        <!-- In Progress Column -->
        <div class="kanban-column" id="in-progress">
            <h3>In Progress</h3>
            <div class="task-list1" id="progress-tasks">
                <div class="task-card" draggable="true">
                    <h4>Task Title 3</h4>
                    <p>Task Description</p>
                    <p><small>Due: 2025-03-21</small></p>
                </div>
            </div>
        </div>

        <!-- Done Column -->
        <div class="kanban-column" id="done">
            <h3>Done</h3>
            <div class="task-list1" id="done-tasks">
                <div class="task-card" draggable="true">
                    <h4>Task Title 4</h4>
                    <p>Task Description</p>
                    <p><small>Completed: 2025-03-19</small></p>
                </div>
            </div>
        </div>

    </div>

    <!-- Floating Quick Add Button -->
    <!-- Quick Add Task Button -->
    <button id="quick-add-task" class="quick-add-btn">＋</button>

    <!-- Modal Placeholder -->
    <div id="modal" class="modal hidden">
      <div class="modal-content">
        <span id="close-modal" class="close-btn">&times;</span>
        <div id="modal-body">
          <!-- Turbo Stream will replace this content -->
        </div>
      </div>
    </div>



          </div>
          <div class="insight">

    <!-- Progress Charts Section -->
    <section class="progress-charts">
        <h2>Task Progress Overview</h2>
        <div class="charts-container">
            <!-- Placeholder for Pie Chart -->
            <div class="chart-card">
                <h3>Completed vs Pending Tasks</h3>
                <div class="chart-placeholder" id="pie-chart-placeholder">
                    <!-- You can later replace this with a real chart (e.g., Chart.js) -->
                    <p>[Pie Chart]</p>
                </div>
            </div>

            <!-- Placeholder for Bar Graph -->
            <div class="chart-card">
                <h3>Tasks by Category</h3>
                <div class="chart-placeholder" id="bar-graph-placeholder">
                    <p>[Bar Graph]</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Daily/Weekly Goal Tracker -->
    <section class="goal-tracker">
        <h2>Daily & Weekly Goals</h2>

        <div class="goal-card">
            <h3>Daily Goal</h3>
            <p>Tasks Completed: <strong>3/5</strong></p>
            <progress value="3" max="5"></progress>
        </div>

        <div class="goal-card">
            <h3>Weekly Goal</h3>
            <p>Tasks Completed: <strong>12/20</strong></p>
            <progress value="12" max="20"></progress>
        </div>
    </section>

    <!-- Activity Log -->
    <section class="activity-log">
        <h2>Recent Activities</h2>
        <ul>
<li>hi</li>
        </ul>
    </section>


