          <div class="team-chat">


  <!-- Chat System Section -->
  <section class="chat-system">
      <h2>Team Chat</h2>
      <div class="chat-box">
          <div class="messages">
              <div class="message received">
                  <strong>Jane:</strong> Hey team! Did anyone check the client feedback yet?
              </div>
              <div class="message sent">
                  <strong>You:</strong> Yes, I reviewed it this morning. Looks good!
              </div>
              <div class="message received">
                  <strong>Mike:</strong> Great! Let's move forward then. @John can you finalize the designs?
              </div>
          </div>
          <div class="chat-input">
              <input type="text" placeholder="Type a message and use @ to mention..." />
              <button>Send</button>
          </div>
      </div>
  </section>

  <!-- Comment Section on Tasks/Projects -->
  <section class="comments-section">
      <h2>Task Comments</h2>
      <div class="comments-box">
          <div class="comment">
              <strong>Sarah:</strong> Don't forget to add the client's logo to the homepage design. <small>1 hour ago</small>
          </div>
          <div class="comment">
              <strong>John:</strong> Sure, I'll do that today. <small>30 minutes ago</small>
          </div>
      </div>
      <div class="comment-input">
          <textarea placeholder="Write a comment... Use @ to mention teammates."></textarea>
          <button>Add Comment</button>
      </div>
  </section>

  <!-- Mentions & Notifications -->
  <section class="notifications-section">
      <h2>Notifications</h2>
