<%= form_with model: task, data: { turbo_frame: "_top" }, class: "task-form" do |f| %>
  <div class="form-group">
    <%= f.label :title, class: "form-label" %>
    <%= f.text_field :title, class: "form-input" %>
  </div>

  <div class="form-group">
    <%= f.label :description, class: "form-label" %>
    <%= f.text_area :description, rows: 4, class: "form-textarea" %>
  </div>

  <div class="form-group">
    <%= f.label :due_date, class: "form-label" %>
    <%= f.date_field :due_date, class: "form-input" %>
  </div>

  <div class="form-group">
    <%= f.submit 'Create Task', class: "form-button" %>
  </div>
<% end %>
